    <!-- 根据 ID 查询采购入库单明细 -->
    <select id="selectEntryByFbillno" parameterType="String" resultType="com.ruoyi.business.entity.PurchaseInStockEntry">
        SELECT * FROM purchase_instock_entry WHERE fbillno = #{fbillno} and fmaterialId = #{fmaterialId}
    </select>

    <select id="selectEntryById" resultType="com.ruoyi.business.entity.PurchaseInStockEntry">
        SELECT
            pin.fbillno,
            byl.number as fmaterialId,
            pin.fmaterialname,
            pin.fmaterialtype,
            pin.fuom,
            bm.name as fstockid,
            pin.fproducedate,
            pin.fnote,
            pin.fwwintype,
            pin.flot,
            wl.location_name as fstocklocid,
            pin.freceivelot,
            pin.fsupplierlot,
            pin.fgrossweight,
            pin.fcontractlno,
            pin.fmustqty,
            pin.frealqty,
            pin.fauxunitqty,
            pin.fexpirydate,
            bymat.name as fstockstatusid,
            pin.fkhhh,
            pin.fbzfyzt,
            cu.fname as fkh,
            syse.fname as fxsyy,
            sysu.user_name as fgdy1,
            pin.fbzyq,
            pin.ftsyq,
            pin.fctybaseproperty,
            pin.fckj,
            pin.fzdrq,
            pin.fddshrq,
            pin.frkzq,
            pin.fkcsl,
            pin.fc,
            pin.fsljzrq,
            pin.ftaxprice,
            pin.fcostprice,
            pin.fentrytax_rate,
            pin.fentrytaxamount,
            pin.fdiscountrate,
            pin.fpricecoefficient,
            pin.fpriceunitqty,
            pin.ftaxnetprice,
            pin.fentrycostamount,
            pin.fallamount,
            pin.ftaxamountlc,
            pin.fcostamountlc,
            pin.fallamountlc,
            pin.fstockflag,
            bdy.name as funitid,
            bldy.name as fbaseunit_id,
            pin.fbaseunitqty,
            pin.fauxunitid,
            byldy.name as fpriceunitid,
            pin.fpoorderno,
            pin.freceivestockstatus,
            pin.fctytext1,
            pin.fpeuuattachmenttzk,
            pin.ftj,
            pin.fpeuubasepropertyre5,
            pin.fssxs,
            pin.foradecimal,
            pin.foramulcombo,
            pin.forapicture,
            pin.fxsdd,
            pin.fjyzt,
            pin.fjydsl,
            bymal.number as fcpbm,
            pin.forabaseproperty,
            pin.fyhbl,
            pin.fyhrq,
            pin.ftaxrate,
            pin.fvat,
            pin.fisreconciliationing,
            pin.freconciliationbillno,
            pin.fctt,
            pin.fjgdz,
            pin.fwxzm,
            pin. fwxcm,
            pin.fct,
            pin.fch,
            pin.fbaozt,
            pin.fnxzm,
            pin.fnxcm,
            pin.fctyattachment
        FROM purchase_instock_entry   pin

                 LEFT JOIN by_material byl on pin.fmaterialId=byl.k3_id
                 LEFT JOIN warehouse_location wl on pin.fstocklocid=wl.location_id
                 LEFT JOIN bd_customer cu on pin.fkh=cu.fcustid
                 LEFT JOIN sys_employee syse on pin.fxsyy=syse.salesman_id
                 LEFT JOIN sys_user sysu on pin.fgdy1=sysu.k3_key
                 LEFT JOIN by_material bymal on pin.fcpbm=bymal.k3_id
                 LEFT JOIN bymaterial_dictionary bdy on pin.funitid=bdy.kingdee and bdy.category='unit'
                 LEFT JOIN bymaterial_dictionary bldy on pin.fbaseunit_id=bldy.kingdee and bldy.category='unit'
                 LEFT JOIN bymaterial_dictionary byldy on pin.fpriceunitid=byldy.kingdee and byldy.category='unit'
                 LEFT JOIN bymaterial_dictionary bm on pin.fstockid=bm.kingdee and bm.category='warehouse'
                 LEFT JOIN bymaterial_dictionary bymat on pin.fstockstatusid=bymat.kingdee and bm.category='inventory_status'


        WHERE fbillno = #{fbillno}
    </select>
</mapper>
