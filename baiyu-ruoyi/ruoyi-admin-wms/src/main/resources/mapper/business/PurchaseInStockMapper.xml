    <!-- 基础查询字段 -->
    <sql id="selectPurchaseInStockVo">
        SELECT
            inst.id,
            inst.fid,
            inst.f_bill_no,
            inst.f_document_status,
            inst.f_date,
            su.name as f_supplier_id,
            sp.name as f_supply_id,
            se.name as f_settle_id,
            sl.name as f_charge_id,
            sely.fname as f_purchaser_id,
            sy.user_name as f_creator_id,
            inst.f_create_date,
            sysu.user_name as f_modifier_id,
            inst.f_modify_date,
            syse.user_name as f_approver_id,
            inst.f_approve_date,
            inst.f_confirmer_id,
            inst.f_confirm_date,
            inst. f_supply_address,
            inst.f_stocker_id,
            byd.name as f_settle_curr_id,
            bydy.name as f_local_curr_id,
            bdy.name as f_exchange_type_id,
            inst.f_exchange_rate,
            inst.f_is_included_tax,
            inst.f_pay_condition_id,
            inst.f_settle_type_id,
            inst.f_price_time_point,
            inst.f_bill_amount,
            inst.f_bill_tax_amount,
            inst.f_bill_all_amount
        FROM
            purchase_instock  inst
                LEFT JOIN supplier su  on inst.f_supplier_id=su.supplierid
                LEFT JOIN supplier sp  on inst.f_supply_id=sp.supplierid
                LEFT JOIN supplier se  on inst.f_settle_id=se.supplierid
                LEFT JOIN supplier sl  on inst.f_charge_id=sl.supplierid
                LEFT JOIN sys_user sy  on inst.f_creator_id=sy.k3_key
                LEFT JOIN sys_user sysu  on inst.f_modifier_id=sysu.k3_key
                LEFT JOIN sys_user syse  on inst.f_approver_id=syse.k3_key
                LEFT JOIN sys_employee sely  on inst.f_purchaser_id=sely.salesman_id
                LEFT JOIN bymaterial_dictionary byd  on inst.f_settle_curr_id=byd.kingdee and byd.category='currency'
                LEFT JOIN bymaterial_dictionary bydy  on inst.f_local_curr_id=bydy.kingdee and bydy.category='currency'
                LEFT JOIN bymaterial_dictionary bdy  on inst.f_exchange_type_id=bdy.kingdee and bdy.category='exchange_type'
    </sql>

    <!-- 查询采购入库单详情 -->
    <select id="selectById" parameterType="String" resultMap="BaseResultMap">
        <include refid="selectPurchaseInStockVo"/>
        WHERE id = #{id}
    </select>

    <!-- 查询采购入库单列表（分页） -->
    <select id="selectList" resultType="com.ruoyi.business.entity.PurchaseInStock">
        <include refid="selectPurchaseInStockVo"/>
        <where>
            1=1
        </where>
        ORDER BY inst.f_create_date DESC
        LIMIT #{page}, #{pageSize}
    </select>

