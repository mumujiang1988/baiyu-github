<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.business.mapper.ReceivebillEntryMapper">
    <select id="selectByIds" resultType="com.ruoyi.business.k3.domain.entity.ReceivebillEntry">
        SELECT
            id,f_entry_id
        FROM f_receivebill_entry
        WHERE f_entry_id = #{fentryId}
    </select>
</mapper>
