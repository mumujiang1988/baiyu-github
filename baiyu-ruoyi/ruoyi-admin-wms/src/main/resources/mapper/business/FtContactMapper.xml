<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.business.mapper.FtContactMapper">
    <select id="selectByIds" resultType="com.ruoyi.business.entity.FtContact">
        SELECT
            id,operator_name,name,job
        FROM ft_contact
        WHERE ft_id = #{ftId}
    </select>
</mapper>
