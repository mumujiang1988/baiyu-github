# ========================================
# 环境变量配置文件
# ========================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=product_search

# CLIP模型配置
CLIP_MODEL=openai/clip-vit-base-patch32
# 国内可使用镜像：https://hf-mirror.com/openai/clip-vit-base-patch32

# FAISS配置
FAISS_INDEX_PATH=product_index.faiss
VECTOR_DIM=512

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
