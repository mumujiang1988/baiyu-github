# 开发环境配置
# 复制到 backend/.env 使用

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=vs_user
MYSQL_PASSWORD=vs_pass123
MYSQL_DB=visual_search

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# OpenCLIP 模型配置
OPENCLIP_MODEL=ViT-B-32
OPENCLIP_PRETRAINED=openai

# HuggingFace 缓存
HF_HUB_OFFLINE=0
HF_HUB_CACHE=./models_cache
TRANSFORMERS_CACHE=./models_cache
MODEL_CACHE_DIR=./models_cache

# Rembg 抠图服务
REMBG_API_URL=http://localhost:7000

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=product-images
MINIO_BUCKET_NAME=product-images  # MinIO Bucket 名称，默认为 product-images
USE_MINIO=true

# ==================== 并发控制 ====================
# 图片入库最大并发数（1-10，默认 4）
MAX_CONCURRENT_INGEST=4

# 图片删除最大并发数（1-10，默认 2）
MAX_CONCURRENT_DELETE=2
